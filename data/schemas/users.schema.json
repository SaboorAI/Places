{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://places.local/schemas/users.schema.json",
  "title": "Users Dataset",
  "type": "object",
  "required": ["users"],
  "properties": {
    "version": {
      "type": "string"
    },
    "users": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name"],
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "homeCityId": { "type": "string" }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
